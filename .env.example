# OpenClaw Release Feed - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===========================================
# GitHub API Token（可选，但推荐配置以避免限流）
# ===========================================
# 创建方式：https://github.com/settings/tokens
# 需要的权限：public_repo (如果仓库是公开的则不需要)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Vercel 环境变量（仅部署时需要）
# ===========================================
# 在 Vercel 项目设置中添加以下变量

# GitHub Token（用于 GitHub Actions 触发部署）
# VERCEL_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
