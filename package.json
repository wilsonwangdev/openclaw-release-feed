{
  "name": "openclaw-release-feed",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "oxlint . && oxfmt --check"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3",
    "@astrojs/tailwind": "^5.1.5",
    "@vercel/analytics": "^2.0.1",
    "astro": "^5.18.1",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "postcss": "^8.4.49",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^3.4.16"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{astro,css}": [
      "oxfmt"
    ],
    "*.md": [
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "simple-git-hooks"
    ]
  }
}
