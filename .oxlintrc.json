{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react"],
  "rules": {
    "no-unused-vars": "warn",
    "react/rules-of-hooks": "error",
    "react/jsx-no-undef": "error",
    "no-console": "warn"
  },
  "overrides": [
    {
      "files": ["scripts/**"],
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "ignorePatterns": ["dist", "node_modules", "src/data/releases.json"]
}
